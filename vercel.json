{
  "version": 2,
  "routes": [
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/order",       "dest": "/pages/order.html" },
    { "src": "/login",       "dest": "/pages/login.html" },
    { "src": "/about",       "dest": "/pages/about.html" },
    { "src": "/admin",       "dest": "/admin/index.html" },
    { "src": "/kasir",       "dest": "/kasir/index.html" },
    { "src": "/",            "dest": "/index.html" },
    { "src": "/(.*)",        "dest": "/$1" }
  ]
}
